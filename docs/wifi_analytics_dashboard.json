          "dataset": "wifi_analytics_db",
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH time_buckets AS (\r\n  -- Zaman eksenini 1'er dakikalık bloklar halinde oluşturuyoruz\r\n  SELECT generate_series(\r\n    date_trunc('minute', $__timeFrom()::timestamp),\r\n    date_trunc('minute', $__timeTo()::timestamp),\r\n    '1 minute'::interval \r\n  ) AS bucket_time\r\n),\r\ndevice_data AS (\r\n  -- Her cihazın hangi dakikalarda online olduğunu buluyoruz\r\n  SELECT \r\n    date_trunc('minute', created_at) as data_time,\r\n    device_mac\r\n  FROM wifi_metrics\r\n  WHERE $__timeFilter(created_at)\r\n  GROUP BY 1, 2\r\n),\r\ntotal_devices AS (\r\n  -- Toplam cihaz sayısını alıyoruz (Envanterdeki benzersiz MAC sayısı)\r\n  SELECT COUNT(DISTINCT device_mac) as total FROM wifi_metrics\r\n)\r\nSELECT\r\n  tb.bucket_time AS \"time\",\r\n  COUNT(DISTINCT dd.device_mac) AS \"Online\",\r\n  (SELECT total FROM total_devices) - COUNT(DISTINCT dd.device_mac) AS \"Offline\"\r\nFROM time_buckets tb\r\nLEFT JOIN device_data dd ON dd.data_time = tb.bucket_time\r\nGROUP BY 1\r\nORDER BY 1;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Online/Offline anlık sayı",
      "type": "timeseries"
