        {
          "dataset": "wifi_analytics_db",
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH HamVeri AS (\r\n  -- Adım 1: Her satırın yanına bir önceki paketin zamanını koyuyoruz\r\n  SELECT \r\n    rssi_a,\r\n    created_at,\r\n    LAG(created_at) OVER (ORDER BY created_at) as onceki_zaman\r\n  FROM wifi_metrics\r\n  WHERE created_at > NOW() - INTERVAL '10 minutes'\r\n),\r\nHesaplanmisMetrikler AS (\r\n  -- Adım 2: RSSI skorunu ve kopma (gap) durumunu belirliyoruz\r\n  SELECT \r\n    CASE \r\n      WHEN rssi_a >= -60 THEN 95 + (rssi_a + 60)\r\n      WHEN rssi_a >= -75 THEN 70 + (rssi_a + 75) * 1.5\r\n      WHEN rssi_a >= -85 THEN 30 + (rssi_a + 85) * 4\r\n      ELSE 0 \r\n    END as satir_skoru,\r\n    -- Eğer iki paket arası 30 saniyeden fazlaysa bunu '1' (kopma) say\r\n    CASE \r\n      WHEN created_at - onceki_zaman > INTERVAL '30 seconds' THEN 1 \r\n      ELSE 0 \r\n    END as kopma_mi\r\n  FROM HamVeri\r\n)\r\n-- Adım 3: Final Skoru Hesapla\r\nSELECT \r\n  GREATEST(0, \r\n    AVG(satir_skoru) - (SUM(kopma_mi) * 10) \r\n  ) as \"Ağ Sağlık Skoru\"\r\nFROM HesaplanmisMetrikler;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Ağ sağlık skoru",
      "type": "gauge"
    },
