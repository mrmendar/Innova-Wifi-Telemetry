      "targets": [
        {
          "dataset": "wifi_analytics_db",
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH GecmisKopmalar AS (\r\n  -- 1. ADIM: Son 8 saat içindeki verileri al ve aradaki boşlukları say\r\n  SELECT \r\n    device_mac,\r\n    COUNT(*) as gecmis_adet\r\n  FROM (\r\n    SELECT \r\n      device_mac,\r\n      created_at,\r\n      created_at - LAG(created_at) OVER (PARTITION BY device_mac ORDER BY created_at) as fark\r\n    FROM wifi_metrics\r\n    WHERE created_at > NOW() - INTERVAL '8 hours' -- Filtre eklendi\r\n  ) t\r\n  WHERE fark > INTERVAL '20 seconds'\r\n  GROUP BY 1\r\n),\r\nCihazBazliSonVeri AS (\r\n  -- 2. ADIM: Son 8 saat içinde en az bir kez görülmüş cihazları bul\r\n  SELECT \r\n    device_name,\r\n    device_mac,\r\n    MAX(created_at) as son_gorulme\r\n  FROM wifi_metrics\r\n  WHERE created_at > NOW() - INTERVAL '8 hours' -- Filtre eklendi\r\n  GROUP BY 1, 2\r\n),\r\nSuAnkiKopma AS (\r\n  -- 3. ADIM: Şu an (son 20 saniyedir) veri gelmiyor mu kontrol et\r\n  SELECT \r\n    device_mac,\r\n    CASE WHEN NOW() - son_gorulme > INTERVAL '20 seconds' THEN 1 ELSE 0 END as aktif_kopma\r\n  FROM CihazBazliSonVeri\r\n)\r\nSELECT \r\n  s.device_name AS \"Cihaz Adı\",\r\n  s.device_mac AS \"MAC Adresi\",\r\n  COALESCE(g.gecmis_adet, 0) + COALESCE(a.aktif_kopma, 0) AS \"Toplam Kopma Adedi\"\r\nFROM CihazBazliSonVeri s\r\nLEFT JOIN GecmisKopmalar g ON s.device_mac = g.device_mac\r\nLEFT JOIN SuAnkiKopma a ON s.device_mac = a.device_mac\r\nWHERE (COALESCE(g.gecmis_adet, 0) + COALESCE(a.aktif_kopma, 0)) > 0 -- Hiç kopmamışları listeden atar\r\nORDER BY \"Toplam Kopma Adedi\" DESC;",
          "refId": "A",
          "sql": {
